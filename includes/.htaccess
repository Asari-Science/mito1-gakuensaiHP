# Deny direct web access to all files in includes/
# (Square credentials and PHP partials must not be served as static files.)

# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 fallback
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>

# Extra belt-and-suspenders: explicitly block sensitive files
<FilesMatch "\.(local\.php|json|env|ini|log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
